# =============================================================================
# GazeAssist Environment Configuration
# Copy this file to .env and fill in values. Do not commit .env with real secrets.
# See SETUP.md for detailed instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# Node backend (API_PORT avoids conflict with React dev server which uses PORT)
# -----------------------------------------------------------------------------
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (optional - for persistent calibration storage)
DATABASE_URL=
DB_SSL=false

# -----------------------------------------------------------------------------
# React frontend - create .env.local and add these (prefix with REACT_APP_)
# Also used by train_from_images.js for API_BASE
# -----------------------------------------------------------------------------
# REACT_APP_API_URL=http://localhost:4000
# REACT_APP_PYTHON_BACKEND=http://localhost:5001
# API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Python backend
# -----------------------------------------------------------------------------
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FLASK_SECRET_KEY=CHANGE_ME_generate_with_command_above

# Optional: Set to 1 to show OpenCV debug windows
# DEBUG=0

# Optional: Reduce OpenCV console output (e.g. SILENT)
# OPENCV_LOG_LEVEL=SILENT
